              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "全デバイスからログアウト",
        "tags": ["セッション"]
      }
    },
    "/auth/forgot-password": {
      "post": {
        "operationId": "AuthController_forgotPassword",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "メール送信（メールアドレス存在有無に関わらず同一レスポンス）。レスポンスボディはありません。"
          },
          "400": {
            "description": "バリデーションエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "パスワードリセットメール送信",
        "tags": ["パスワード"]
      }
    },
    "/auth/validate-reset-token": {
      "post": {
        "operationId": "AuthController_validateResetToken",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateResetTokenRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "トークン有効。レスポンスボディはありません。"
          },
          "400": {
            "description": "バリデーションエラー（message: string[]）またはトークン不正 / 期限切れ（message: string）",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ValidationErrorResponseDto"
                    },
                    {
                      "$ref": "#/components/schemas/BadRequestErrorResponseDto"
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "パスワードリセットトークン検証",
        "tags": ["パスワード"]
      }
    },
    "/auth/reset-password": {
      "post": {
        "operationId": "AuthController_resetPassword",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "パスワードリセット成功。新しいトークンを発行",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "トークン不正 / 期限切れ / バリデーションエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "パスワードリセット実行",
        "tags": ["パスワード"]
      }
    },
    "/auth/change-password": {
      "patch": {
        "operationId": "AuthController_changePassword",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "パスワード変更成功。全デバイスのリフレッシュトークンを削除し Cookie をクリア。"
          },
          "400": {
            "description": "バリデーションエラー（message: string[]）または現在のパスワード不一致（message: string）",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ValidationErrorResponseDto"
                    },
                    {
                      "$ref": "#/components/schemas/BadRequestErrorResponseDto"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "トークン無効",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedErrorResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "refresh_token": []
          },
          {
            "bearer": []
          }
        ],
        "summary": "パスワード変更（ログイン済み）",
        "tags": ["パスワード"]
      }
    },
    "/auth/exchange": {
      "post": {
        "operationId": "AuthController_exchange",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExchangeRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "認可コード発行成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExchangeResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "redirect のオリジンが許可リスト外",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequestErrorResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "アクセストークン不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedErrorResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "認可コード発行（SSO用）",
        "tags": ["SSO"]
      }
    },
    "/auth/exchange/verify": {
      "post": {
        "operationId": "AuthController_verifyExchange",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyExchangeRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "検証成功。アクセストークンを発行",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyExchangeResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "リクエストボディ不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequestErrorResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "認可コード不正・期限切れ・既使用",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedErrorResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "認可コード検証（SSO用・サーバー間通信）",
        "tags": ["SSO"]
      }
    }
  },
  "info": {
    "title": "株式会社waddleの認証API",
    "description": "株式会社waddleの認証関連APIドキュメント",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "refresh_token": {
        "type": "apiKey",
        "in": "cookie",
        "name": "refresh_token"
      }
    },
    "schemas": {
      "BadRequestErrorResponseDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "現在のパスワードが正しくありません"
          },
          "error": {
            "type": "string",
            "example": "Bad Request"
          }
        },
        "required": ["statusCode", "message", "error"]
      },
      "SignupRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          }
        },
        "required": ["email"]
      },
      "ValidationErrorResponseDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 400
          },
          "message": {
            "example": [
              "email must be an email",
              "password must be longer than or equal to 8 characters"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "error": {
            "type": "string",
            "example": "Bad Request"
          }
        },
        "required": ["statusCode", "message", "error"]
      },
      "ConflictErrorResponseDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 409
          },
          "message": {
            "type": "string",
            "example": "このメールアドレスは既に使用されています"
          },
          "error": {
            "type": "string",
            "example": "Conflict"
          }
        },
        "required": ["statusCode", "message", "error"]
      },
      "InternalServerErrorResponseDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 500
          },
          "message": {
            "type": "string",
            "example": "サーバーエラー"
          },
          "error": {
            "type": "string",
            "example": "Internal Server Error"
          }
        },
        "required": ["statusCode", "message", "error"]
      },
      "VerifyEmailRequestDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "メールアドレス確認トークン"
          }
        },
        "required": ["token"]
      },
      "VerifyEmailResponseDto": {
        "type": "object",
        "properties": {
          "setupToken": {
            "type": "string",
            "description": "初期設定用ワンタイムトークン"
          }
        },
        "required": ["setupToken"]
      },
      "SetupRequestDto": {
        "type": "object",
        "properties": {
          "setupToken": {
            "type": "string",
            "example": "setup-token"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "minLength": 8
          }
        },
        "required": ["setupToken", "password"]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": ["accessToken"]
      },
      "LoginRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          }
        },
        "required": ["email", "password"]
      },
      "UnauthorizedErrorResponseDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 401
          },
          "message": {
            "type": "string",
            "example": "メールアドレスまたはパスワードが正しくありません"
          },
          "error": {
            "type": "string",
            "example": "Unauthorized"
          }
        },
        "required": ["statusCode", "message", "error"]
      },
      "ForgotPasswordRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "メールアドレス"
          }
        },
        "required": ["email"]
      },
      "ValidateResetTokenRequestDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "パスワードリセットトークン"
          }
        },
        "required": ["token"]
      },
      "ResetPasswordRequestDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "パスワードリセットトークン"
          },
          "newPassword": {
            "type": "string",
            "example": "NewP@ssw0rd!",
            "description": "新しいパスワード（8文字以上）"
          }
        },
        "required": ["token", "newPassword"]
      },
      "ChangePasswordRequestDto": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string",
            "description": "現在のパスワード"
          },
          "newPassword": {
            "type": "string",
            "example": "NewP@ssw0rd!",
            "description": "新しいパスワード（8文字以上）"
          }
        },
        "required": ["currentPassword", "newPassword"]
      },
      "ExchangeRequestDto": {
        "type": "object",
        "properties": {
          "redirect": {
            "type": "string",
            "description": "遷移先のコールバック URL",
            "example": "http://localhost:3002/callback"
          }
        },
        "required": ["redirect"]
      },
      "ExchangeResponseDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "認可コード"
          }
        },
        "required": ["code"]
      },
      "VerifyExchangeRequestDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "認可コード"
          }
        },
        "required": ["code"]
      },
      "ExchangeUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ユーザー ID"
          },
          "email": {
            "type": "string",
