              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "refresh_token": []
          }
        ],
        "summary": "トークンリフレッシュ（Cookie の refresh_token を使用）",
        "tags": ["セッション"]
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "200": {
            "description": "ログアウト成功。レスポンスボディはありません。"
          },
          "401": {
            "description": "トークン無効",
